# SupplAI environment variables
# Copy this file to .env and fill only the keys you want to use.

# --- AI providers (optional) ---
# Gemini / Google GenAI (any one of these names is accepted by the app)
GEMINI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_GENAI_API_KEY=

# Groq (used for AI brief fallback and autonomous agent mode)
GROQ_API_KEY=

# --- Weather provider (optional) ---
# OpenWeather (any one of these names is accepted by the app)
OPENWEATHER_API_KEY=
OPENWEATHERMAP_API_KEY=
OWM_API_KEY=
